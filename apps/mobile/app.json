{
  "expo": {
    "name": "Quanta Wallet",
    "slug": "quanta-wallet",
    "version": "0.0.16",
    "orientation": "portrait",
    "scheme": "quanta",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#050505"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.quanta.wallet"
    },
    "android": {
      "package": "com.quanta.wallet",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#050505"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-secure-store",
        {
          "faceIDPermission": "Allow Quanta Wallet to unlock your account keys with Face ID."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
