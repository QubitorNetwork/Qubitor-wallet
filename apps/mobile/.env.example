# Set to 1 to expose prototype debug affordances:
# - "State: …" cycle buttons on every screen for design review
# - Future debug-only inspectors and forced-state toggles
#
# Unset (default) for shareable / production builds.
EXPO_PUBLIC_QUBITOR_DEBUG=1

# Set to 1 in native release builds to require device authentication before
# reading or updating the on-device ML-DSA profile.
EXPO_PUBLIC_QUBITOR_REQUIRE_BIOMETRIC=0

# Default: live Qubitor Testnet (the product default network).
EXPO_PUBLIC_QUBITOR_RPC_URL=https://testrpc.qubitor.org/rpc
EXPO_PUBLIC_QUBITOR_FAUCET_URL=https://testrpc.qubitor.org
EXPO_PUBLIC_QUBITOR_PQ_RELAYER_URL=https://testrpc.qubitor.org

# Local Qubitor devnet alternative.
# Start a local Qubitor Network devnet first, for example from a sibling QubitorNetwork checkout:
# pnpm coregeth:build && pnpm devnet:start && pnpm contracts:deploy:devnet
# EXPO_PUBLIC_QUBITOR_CHAIN_ID=91337
# EXPO_PUBLIC_QUBITOR_RPC_URL=http://127.0.0.1:18545/rpc
# EXPO_PUBLIC_QUBITOR_FAUCET_URL=http://127.0.0.1:18546
# EXPO_PUBLIC_QUBITOR_PQ_RELAYER_URL=http://127.0.0.1:18548

# Supported chain IDs: 91337 (Qubitor Devnet), 91338 (Qubitor Testnet).
EXPO_PUBLIC_QUBITOR_CHAIN_ID=91338

# Optional account address override for live balance/deployment reads.
# Defaults to the prototype Qubitor Account address in mockData.ts.
EXPO_PUBLIC_QUBITOR_ACCOUNT_ADDRESS=
