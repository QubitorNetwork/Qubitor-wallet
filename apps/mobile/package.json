{
  "name": "@qubitor/mobile",
  "version": "0.0.25",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build": "expo export",
    "build:web": "expo export --platform web",
    "devnet:acceptance": "NODE_OPTIONS=--conditions=import tsx scripts/devnet-acceptance.ts",
    "devnet:rotate-acceptance": "NODE_OPTIONS=--conditions=import tsx scripts/devnet-rotation-acceptance.ts",
    "devnet:ui-smoke": "node scripts/devnet-ui-smoke.mjs",
    "pq-vault:generate": "NODE_OPTIONS=--conditions=import tsx scripts/pq-vault-generate.ts",
    "typecheck": "tsc --noEmit",
    "lint": "expo lint"
  },
  "dependencies": {
    "@babel/runtime": "^7.29.2",
    "@expo-google-fonts/inter": "^0.2.3",
    "@expo-google-fonts/jetbrains-mono": "^0.2.3",
    "@expo-google-fonts/manrope": "^0.2.3",
    "@expo-google-fonts/roboto-mono": "^0.2.3",
    "@expo-google-fonts/space-grotesk": "^0.2.3",
    "@expo/metro-runtime": "4.0.1",
    "@qubitor/chain-config": "0.1.1",
    "@qubitor/core": "workspace:*",
    "@qubitor/evm": "workspace:*",
    "@qubitor/keystore": "workspace:*",
    "@qubitor/pq-crypto": "workspace:*",
    "@qubitor/pq-native-tx": "0.1.1",
    "@qubitor/sdk": "0.1.1",
    "@qubitor/ui-tokens": "workspace:*",
    "@qubitor/wallet-policy": "workspace:*",
    "@react-native-async-storage/async-storage": "1.23.1",
    "expo": "~52.0.0",
    "expo-asset": "~11.0.5",
    "expo-camera": "~16.0.18",
    "expo-clipboard": "~7.0.1",
    "expo-crypto": "~14.0.2",
    "expo-font": "~13.0.0",
    "expo-linking": "~7.0.0",
    "expo-router": "~4.0.0",
    "expo-secure-store": "~14.0.1",
    "expo-splash-screen": "~0.29.0",
    "expo-status-bar": "~2.0.0",
    "expo-system-ui": "~4.0.0",
    "lucide-react-native": "^0.468.0",
    "nativewind": "^4.1.23",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.5",
    "react-native-css-interop": "0.2.3",
    "react-native-gesture-handler": "~2.20.0",
    "react-native-qrcode-svg": "^6.3.14",
    "react-native-reanimated": "~3.16.0",
    "react-native-safe-area-context": "~4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-svg": "^15.8.0",
    "react-native-web": "~0.19.13",
    "react-native-worklets": "0.5.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@types/react": "~18.3.12",
    "babel-preset-expo": "~12.0.12",
    "eslint": "^8.57.1",
    "eslint-config-expo": "~8.0.1",
    "playwright-core": "^1.59.1",
    "tailwindcss": "^3.4.16",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3"
  }
}
