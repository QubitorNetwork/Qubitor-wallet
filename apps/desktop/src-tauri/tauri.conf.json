{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Quanta Wallet",
  "version": "0.0.23",
  "identifier": "org.quanta.wallet",
  "build": {
    "frontendDist": "../../mobile/dist",
    "beforeBuildCommand": "pnpm --filter @qubitor/mobile build:web"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Quanta Wallet",
        "width": 420,
        "height": 860,
        "minWidth": 380,
        "minHeight": 640,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app",
      "dmg",
      "nsis",
      "msi",
      "appimage",
      "deb"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Finance",
    "shortDescription": "Quanta Wallet — post-quantum smart account",
    "longDescription": "Quanta Wallet desktop — a Qubitor Network post-quantum (ML-DSA) smart-account wallet. Keys are stored in the OS keychain."
  },
  "plugins": {}
}
