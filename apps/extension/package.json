{
  "name": "@qubitor/extension",
  "version": "0.0.16",
  "private": true,
  "displayName": "Quanta Wallet",
  "description": "Quanta Wallet browser extension — Qubitor Network smart account with PQ-native validation.",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "typecheck": "tsc --noEmit",
    "testnet:acceptance": "NODE_OPTIONS=--conditions=import tsx scripts/testnet-acceptance.ts",
    "package": "plasmo package"
  },
  "dependencies": {
    "@qubitor/chain-config": "0.1.1",
    "@qubitor/core": "workspace:*",
    "@qubitor/evm": "workspace:*",
    "@qubitor/pq-crypto": "workspace:*",
    "@qubitor/pq-native-tx": "0.1.1",
    "@qubitor/sdk": "0.1.1",
    "@qubitor/ui-tokens": "workspace:*",
    "@qubitor/wallet-policy": "workspace:*",
    "lucide-react": "^0.468.0",
    "plasmo": "^0.89.4",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "viem": "^2.21.55"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.287",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.0",
    "tailwindcss": "^3.4.16",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3"
  },
  "manifest": {
    "host_permissions": [
      "https://*/*",
      "http://*/*"
    ],
    "permissions": [
      "storage",
      "tabs"
    ]
  }
}
